# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o

# GitHub (required to avoid anonymous rate limit of 60 req/hr)
GITHUB_TOKEN=ghp_...

# Vector DB
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=embodied_knowledge

# Pinecone (optional for production)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=embodiedmind

# Search
TAVILY_API_KEY=

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=200

# Rate Limiting
CRAWL_DELAY_SECONDS=1.0
GITHUB_API_MAX_PER_HOUR=4500

# Compliance (required)
BOT_CONTACT_EMAIL=your@email.com
